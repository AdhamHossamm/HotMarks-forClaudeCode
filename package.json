{
  "name": "hotmarks",
  "version": "0.0.2",
  "type": "module",
  "description": "Semantic formatting plugin for Claude Code. **Bold** = directive. __Underline__ = critical emphasis.",
  "main": "dist/hook.js",
  "bin": {
    "hotmarks": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude-code",
    "plugin",
    "semantic",
    "formatting",
    "directive"
  ],
  "author": "AdhamHossamm",
  "license": "MIT",
  "homepage": "https://github.com/AdhamHossamm/HotMarks-forClaudeCode#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AdhamHossamm/HotMarks-forClaudeCode.git"
  },
  "bugs": {
    "url": "https://github.com/AdhamHossamm/HotMarks-forClaudeCode/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.6"
  }
}
